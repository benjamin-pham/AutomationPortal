# ── Copy this file to .env and fill in your values ────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=myprojectdemo
POSTGRES_USER=admin
POSTGRES_PASSWORD=Admin@123456
# Host port that PostgreSQL is mapped to (internal is always 5432)
POSTGRES_PORT=5534

# ── Backend (.NET API) ─────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=5800

# JWT — change SecretKey in production (min 32 chars)
JWT_SECRET_KEY=your-super-secret-key-at-least-32-chars
JWT_ISSUER=AutomationPortal
JWT_AUDIENCE=AutomationPortal

# ── Seq (log viewer) ───────────────────────────────────────────────────────────
# UI accessible at http://localhost:<SEQ_UI_PORT>
SEQ_UI_PORT=5344
# Ingest port used by the backend to send logs
SEQ_INGEST_PORT=5344
# Optional Seq API key (leave empty for dev)
SEQ_API_KEY=

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
FRONTEND_PORT=3010
